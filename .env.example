# =============================================================================
# Lafiga API – environment variables
# Copy to `.env` (not committed) and adjust per environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Rails core
# -----------------------------------------------------------------------------
RAILS_ENV=production
# Required in production. Generate with: `bin/rails secret`
SECRET_KEY_BASE=

# Set to `1` (or any non-empty value) to log to STDOUT (Docker/Kubernetes/PaaS).
RAILS_LOG_TO_STDOUT=1
# Default `info`. Use `debug` only for short-lived triage windows.
RAILS_LOG_LEVEL=info

# Concurrent threads per Puma worker. Must equal database pool size.
RAILS_MAX_THREADS=5

# -----------------------------------------------------------------------------
# Database (Postgres)
# Production prefers DATABASE_URL. Discrete vars are a fallback for
# self-hosted Docker / VPS setups where DATABASE_URL is not provided.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:password@host:5432/lafiga_production
# DATABASE_HOST=lafiga_db
# DATABASE_USER=lafiga_api
# DATABASE_PASSWORD=changeme
# DATABASE_NAME=lafiga-api_production
# DATABASE_SSLMODE=require   # Render/Heroku managed PG require SSL

# -----------------------------------------------------------------------------
# Redis (Action Cable + Rails cache)
# Required in production. Action Cable uses logical DB /1; the cache store
# defaults to the same URL but you can split them via CACHE_REDIS_URL.
# -----------------------------------------------------------------------------
REDIS_URL=redis://default:password@host:6379/1
# CACHE_REDIS_URL=redis://default:password@host:6379/2
# ACTION_CABLE_CHANNEL_PREFIX=lafiga-api_production

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# JsonWebToken (lib/json_web_token.rb) signs / verifies tokens with
# Rails.application.secrets.secret_key_base, i.e. the SECRET_KEY_BASE above.
# There is intentionally no separate JWT_SECRET env var.
#
# Optional: how long an issued JWT remains valid (1..365 days, default 30).
# JWT_EXPIRATION_DAYS=30

# -----------------------------------------------------------------------------
# CORS / Action Cable origins
# Comma-separated list of full origins (no trailing slash).
# Used by both CORS (config/initializers/cors.rb) and Action Cable
# (config/environments/production.rb).
# -----------------------------------------------------------------------------
FRONTEND_ORIGINS=https://app.lafiga.app,https://www.lafiga.app
ACTION_CABLE_ALLOWED_ORIGINS=https://app.lafiga.app,https://www.lafiga.app

# -----------------------------------------------------------------------------
# Static files / SSL
# -----------------------------------------------------------------------------
# Enable Rails to serve files from /public (needed when there is no Nginx
# in front and the platform doesn't strip the path). Required on Heroku.
RAILS_SERVE_STATIC_FILES=1
# Set to `false` ONLY when behind a proxy that doesn't forward HTTPS info,
# or for local container testing.
FORCE_SSL=true

# -----------------------------------------------------------------------------
# Optional: third-party integrations
# -----------------------------------------------------------------------------
# Used by lib/google_drive integration (translation key import). Mount as a
# JSON file or paste the contents inline depending on your platform.
# GOOGLE_TRANSLATE_KEY_PATH=/app/translate-key.json
